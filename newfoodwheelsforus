<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>食乜好？旋轉轉盤｜優化版</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: linear-gradient(145deg, #2b3a4a 0%, #1d2a35 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: -apple-system, 'Segoe UI', 'Helvetica Neue', 'Noto Sans', system-ui, sans-serif;
            padding: 16px;
            margin: 0;
            touch-action: pan-y;
        }

        .card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border-radius: 48px 48px 36px 36px;
            box-shadow: 0 25px 40px rgba(0, 0, 0, 0.5), 0 0 0 2px rgba(255, 215, 120, 0.2) inset;
            padding: 24px 24px 36px;
            max-width: 700px;
            width: 100%;
        }

        h1 {
            text-align: center;
            font-weight: 600;
            font-size: 2.4rem;
            letter-spacing: 2px;
            color: #ffecb3;
            text-shadow: 0 4px 0 #8b6f4c, 0 8px 10px rgba(0,0,0,0.4);
            margin-top: -8px;
            margin-bottom: 16px;
        }

        .wheel-container {
            position: relative;
            display: flex;
            justify-content: center;
            margin: 8px 0 18px;
            touch-action: none;
        }

        canvas {
            display: block;
            width: 100%;
            height: auto;
            aspect-ratio: 1/1;
            max-width: 500px;
            border-radius: 50%;
            box-shadow: 0 20px 30px rgba(0, 0, 0, 0.7), 0 0 0 6px #f7d9a0, 0 0 0 12px #9e7e5e;
            background: #3e2e1f;
            transition: box-shadow 0.2s;
            touch-action: none;
        }

        .pointer {
            position: absolute;
            top: -2px;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 0;
            border-left: 28px solid transparent;
            border-right: 28px solid transparent;
            border-top: 48px solid #d43223;
            filter: drop-shadow(0 12px 6px rgba(0,0,0,0.5));
            z-index: 10;
            pointer-events: none;
        }

        .pointer::after {
            content: "";
            position: absolute;
            top: -52px;
            left: -10px;
            width: 20px;
            height: 20px;
            background: radial-gradient(circle, #ffd966, #b87c10);
            border-radius: 50%;
            box-shadow: 0 0 0 4px #f1c40f;
        }

        .result-panel {
            background: #2e3b47;
            border-radius: 60px;
            padding: 18px 24px;
            margin: 28px 0 20px;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;
            gap: 18px 30px;
            box-shadow: inset 0 3px 10px #0f1a24, 0 10px 10px rgba(0, 0, 0, 0.4);
            border: 1px solid #f7c46e;
        }

        .result-label {
            font-size: 1.5rem;
            font-weight: 600;
            color: #ffd966;
            text-shadow: 0 2px 0 #6b4f2a;
            background: #1f2b33;
            padding: 8px 22px;
            border-radius: 40px;
            box-shadow: inset 0 -2px 0 #384b5a;
        }

        .result-value {
            font-size: 2.2rem;
            font-weight: 700;
            background: #fcf3e0;
            padding: 10px 36px;
            border-radius: 50px;
            color: #1e2b32;
            min-width: 180px;
            text-align: center;
            box-shadow: 0 4px 0 #b38b54, 0 8px 12px black;
            letter-spacing: 1px;
            border: 2px solid #f3b33d;
        }

        .spin-btn {
            background: #f3b33d;
            border: none;
            padding: 20px 40px;
            border-radius: 50px;
            font-size: 2rem;
            font-weight: 800;
            color: #282828;
            text-transform: uppercase;
            letter-spacing: 4px;
            box-shadow: 0 12px 0 #9e601d, 0 10px 20px black;
            transition: all 0.08s linear;
            width: fit-content;
            margin: 0 auto 8px;
            cursor: pointer;
            border: 2px solid #ffdd9e;
            -webkit-appearance: none;
            touch-action: manipulation;
        }

        .spin-btn:active {
            transform: translateY(8px);
            box-shadow: 0 4px 0 #9e601d, 0 10px 20px black;
        }

        .spin-btn:disabled {
            opacity: 0.7;
            transform: translateY(5px);
            box-shadow: 0 6px 0 #7b4c1f;
            cursor: not-allowed;
        }

        .footer-note {
            text-align: center;
            color: #cdba95;
            font-size: 1.1rem;
            margin-top: 20px;
            font-weight: 500;
            text-shadow: 0 1px 2px black;
        }

        .footer-note span {
            background: #1b2a33;
            padding: 4px 14px;
            border-radius: 30px;
            display: inline-block;
        }

        @media (max-width: 500px) {
            h1 { font-size: 2rem; }
            .result-value { font-size: 1.8rem; padding: 8px 18px; min-width: 150px; }
            .spin-btn { font-size: 1.8rem; padding: 16px 30px; }
            .pointer { border-left: 20px solid transparent; border-right: 20px solid transparent; border-top: 36px solid #d43223; }
            .pointer::after { top: -40px; left: -8px; width: 16px; height: 16px; }
        }
    </style>
</head>
<body>
<div class="card">
    <h1>🍜 是日食乜好？ 🍛</h1>

    <div class="wheel-container">
        <div class="pointer"></div>
        <canvas id="wheelCanvas" width="500" height="500"></canvas>
    </div>

    <div class="result-panel">
        <span class="result-label">今日推介</span>
        <span class="result-value" id="selectedResult">麵類</span>
    </div>

    <button class="spin-btn" id="spinButton">🔄 旋轉</button>
    <div class="footer-note"><span>13款選項 · 指針靜止為準</span></div>
</div>

<script>
    (function() {
        // ----- 選項設定 -----
        const options = [
            "麵類", "茶餐廳", "大排檔/熟食中心", "cafe", "日式放題",
            "火鍋", "泰式", "韓國", "意大利", "燒味", "掃街", "壽司", "foodcourt"
        ];
        const sectorCount = options.length;
        const anglePerSector = (Math.PI * 2) / sectorCount;

        // 配色（13色）
        const colorPalette = [
            "#FFB3BA", "#FFDFBA", "#FFFFBA", "#BAFFC9", "#BAE1FF",
            "#D4A5A5", "#E8D0B3", "#C4E0D9", "#B2C8DF", "#FBC8D5",
            "#C5A9DF", "#B0E0E6", "#FED7B0"
        ];

        // DOM 元素
        const canvas = document.getElementById('wheelCanvas');
        const ctx = canvas.getContext('2d');
        const spinBtn = document.getElementById('spinButton');
        const resultSpan = document.getElementById('selectedResult');

        // 幾何常數
        const centerX = 250, centerY = 250;
        const radius = 220;
        const textRadius = radius * 0.72;      // 文字擺放半徑
        const pointerAngle = (3 * Math.PI) / 2; // 指針指向 270° (向上)

        // 旋轉狀態
        let currentRotation = 0.85;      // 初始偏移弧度
        let animFrameId = null;
        let isSpinning = false;
        
        // 預先計算每個選項的最佳字體大小（優化繪製效能）
        let fontSizeCache = [];

        // ----- 輔助函數 -----
        function normalizeAngle(angle) {
            const twoPI = Math.PI * 2;
            angle = angle % twoPI;
            if (angle < 0) angle += twoPI;
            return angle;
        }

        // 根據當前旋轉角度計算指針指向的選項索引
        function getSelectedIndex(rot) {
            const normRot = normalizeAngle(rot);
            let rawAngle = normalizeAngle(pointerAngle - normRot);
            let index = Math.floor(rawAngle / anglePerSector);
            if (index >= sectorCount) index = sectorCount - 1;
            return index;
        }

        function updateResultText() {
            const idx = getSelectedIndex(currentRotation);
            resultSpan.innerText = options[idx];
        }

        // 計算適合某段文字的畫布字體大小（基於弦長限制）
        function getOptimalFontSize(text, maxChordLength, ctx, minFont = 9, maxFont = 24) {
            let fontSize = maxFont;
            ctx.font = `bold ${fontSize}px -apple-system, 'Segoe UI', 'Helvetica Neue', 'Noto Sans', system-ui, sans-serif`;
            let textWidth = ctx.measureText(text).width;
            while (textWidth > maxChordLength && fontSize > minFont) {
                fontSize -= 1;
                ctx.font = `bold ${fontSize}px -apple-system, 'Segoe UI', 'Helvetica Neue', 'Noto Sans', system-ui, sans-serif`;
                textWidth = ctx.measureText(text).width;
            }
            return fontSize;
        }

        // 預先計算所有扇區的文字字體大小（只在初始化時執行一次）
        function computeFontSizes() {
            const maxChordLength = 2 * textRadius * Math.sin(anglePerSector / 2) * 0.9;
            for (let i = 0; i < sectorCount; i++) {
                const text = options[i];
                let fontSize = getOptimalFontSize(text, maxChordLength, ctx, 9, 26);
                fontSizeCache.push(fontSize);
            }
        }

        // 繪製整個轉盤 (根據 currentRotation)
        function drawWheel() {
            const rot = currentRotation;
            ctx.clearRect(0, 0, 500, 500);

            // 1. 繪製扇區
            for (let i = 0; i < sectorCount; i++) {
                const start = rot + i * anglePerSector;
                const end = start + anglePerSector;
                ctx.beginPath();
                ctx.moveTo(centerX, centerY);
                ctx.arc(centerX, centerY, radius, start, end);
                ctx.closePath();
                ctx.fillStyle = colorPalette[i % colorPalette.length];
                ctx.fill();
                ctx.strokeStyle = "#fcf3e0";
                ctx.lineWidth = 2.2;
                ctx.stroke();
            }

            // 2. 外圈裝飾
            ctx.beginPath();
            ctx.arc(centerX, centerY, radius, 0, Math.PI * 2);
            ctx.strokeStyle = "#ffd966";
            ctx.lineWidth = 6;
            ctx.stroke();

            // 3. 中心圓
            ctx.beginPath();
            ctx.arc(centerX, centerY, 22, 0, 2 * Math.PI);
            ctx.fillStyle = "#f7d9a0";
            ctx.fill();
            ctx.strokeStyle = "#9e7e5e";
            ctx.lineWidth = 4;
            ctx.stroke();

            // 4. 繪製文字（使用預先算好的字體大小，並加上陰影增強可讀性）
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            ctx.shadowColor = "rgba(0,0,0,0.6)";
            ctx.shadowBlur = 4;
            ctx.shadowOffsetX = 1;
            ctx.shadowOffsetY = 1;

            for (let i = 0; i < sectorCount; i++) {
                const midAngle = rot + (i + 0.5) * anglePerSector;
                const textX = centerX + Math.cos(midAngle) * textRadius;
                const textY = centerY + Math.sin(midAngle) * textRadius;
                const text = options[i];
                const fontSize = fontSizeCache[i];
                ctx.font = `bold ${fontSize}px -apple-system, 'Segoe UI', 'Helvetica Neue', 'Noto Sans', system-ui, sans-serif`;
                
                // 先繪深色背景邊緣，再繪亮色文字，確保對比
                ctx.fillStyle = "#1f262a";
                ctx.fillText(text, textX, textY);
                ctx.fillStyle = "#fef9e8";
                ctx.fillText(text, textX, textY);
            }
            ctx.shadowBlur = 0;
            ctx.shadowOffsetX = 0;
            ctx.shadowOffsetY = 0;
        }

        // ----- 優化後的動畫系統 (基於時間的 easeOutCubic) -----
        function easeOutCubic(t) {
            return 1 - Math.pow(1 - t, 3);
        }

        let animStartTime = 0;
        let animStartRot = 0;
        let animDeltaRot = 0;
        let animDuration = 0;

        function startSpin() {
            if (isSpinning) return;

            // 隨機轉數：5 ~ 12 圈 + 隨機偏移 (0~2π)
            const minTurns = 5;
            const maxTurns = 12;
            const turns = minTurns + Math.random() * (maxTurns - minTurns);
            const randomOffset = Math.random() * 2 * Math.PI;
            const totalDelta = turns * 2 * Math.PI + randomOffset;
            
            animStartRot = currentRotation;
            animDeltaRot = totalDelta;
            animDuration = 800;  // 毫秒，可調整流暢度
            animStartTime = performance.now();
            
            isSpinning = true;
            spinBtn.disabled = true;
            
            if (animFrameId) cancelAnimationFrame(animFrameId);
            animFrameId = requestAnimationFrame(animateSpin);
        }

        function animateSpin(now) {
            const elapsed = now - animStartTime;
            let progress = Math.min(1, elapsed / animDuration);
            const easeProgress = easeOutCubic(progress);
            
            // 更新當前旋轉角度
            currentRotation = animStartRot + animDeltaRot * easeProgress;
            drawWheel();
            
            if (progress < 1) {
                animFrameId = requestAnimationFrame(animateSpin);
            } else {
                // 動畫結束：精確歸位到目標值，歸一化，更新結果
                currentRotation = animStartRot + animDeltaRot;
                currentRotation = normalizeAngle(currentRotation);
                drawWheel();
                updateResultText();
                
                isSpinning = false;
                spinBtn.disabled = false;
                animFrameId = null;
            }
        }

        // ----- 初始化 & 事件綁定 -----
        function init() {
            computeFontSizes();          // 預先計算字體大小
            drawWheel();
            updateResultText();
            
            spinBtn.addEventListener('click', startSpin);
            // 防止觸控拖曳 canvas 造成頁面滾動
            canvas.addEventListener('touchstart', (e) => e.preventDefault());
            canvas.addEventListener('mousedown', (e) => e.preventDefault());
        }

        init();
    })();
</script>
</body>
</html>
